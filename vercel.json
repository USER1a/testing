{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/movie-player run build",
  "outputDirectory": "artifacts/movie-player/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
